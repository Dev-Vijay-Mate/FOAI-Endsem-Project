{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/iss/:match*",
      "destination": "http://api.open-notify.org/:match*"
    },
    {
      "source": "/api/nominatim/:match*",
      "destination": "https://nominatim.openstreetmap.org/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
